// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // or "postgresql" / "mysql" depending on your setup
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  posts    Post[]
}

model Post {
  id        Int    @id @default(autoincrement())
  content   String
  authorId  Int
  author    User   @relation(fields: [authorId], references: [id])
}